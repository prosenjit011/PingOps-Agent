# AIC Sentinel Configuration

# Server port
PORT=3000

# Default tenant connection (optional - can also be set in the UI)
TENANT_URL=https://your-tenant.forgeblocks.com
API_KEY_ID=your-api-key-id-here
API_KEY_SECRET=your-api-key-secret-here

# Polling frequency in seconds (default: 10)
POLL_FREQUENCY=10

# Maximum log buffer size in the browser (default: 5000)
MAX_LOG_BUFFER=5000

# E2E test credentials (required for npm run test:e2e)
TEST_USER=your-test-username
TEST_PASS=your-test-password
